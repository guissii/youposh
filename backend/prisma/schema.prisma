generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  nameAr   String    @default("")
  icon     String    @default("")
  image    String    @default("")
  slug     String    @unique
  products Product[]
  attributes CategoryAttribute[]
}

model GlobalAttribute {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  nameAr    String   @default("")
  isMulti   Boolean  @default(true)
  sortOrder Int      @default(0)
  values    GlobalAttributeValue[]
  categoryLinks CategoryAttribute[]
}

model GlobalAttributeValue {
  id          Int            @id @default(autoincrement())
  attribute   GlobalAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId Int
  value       String
  valueAr     String         @default("")
  sortOrder   Int            @default(0)
  categoryValueLinks CategoryAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
}

model Product {
  id            Int         @id @default(autoincrement())
  name          String
  nameAr        String      @default("")
  price         Float
  originalPrice Float?
  image         String      @default("")
  images        String[]    @default([])
  badge         String?
  rating        Float       @default(0)
  reviews       Int         @default(0)
  categorySlug  String?
  category      Category?   @relation(fields: [categorySlug], references: [slug])
  description   String      @default("")
  descriptionAr String      @default("")
  inStock       Boolean     @default(true)
  isVisible     Boolean     @default(true)
  sku           String      @default("")
  tags          String[]    @default([])
  features      String[]    @default([])
  variants      Json        @default("[]")
  isPopular     Boolean     @default(false)
  isNew         Boolean     @default(false)
  isBestSeller  Boolean     @default(false)
  isFeatured    Boolean     @default(false)
  status        String      @default("published")
  publishedAt   DateTime?
  sortOrder     Int         @default(0)
  viewsCount    Int         @default(0)
  cartAddCount  Int         @default(0)
  salesCount    Int         @default(0)
  stock         Int         @default(0)
  cardZoom      Float       @default(1.0)
  cardFocalX    Float       @default(50)
  cardFocalY    Float       @default(50)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  attributeValues ProductAttributeValue[]
}

model CategoryAttribute {
  id        Int      @id @default(autoincrement())
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int
  globalAttribute GlobalAttribute? @relation(fields: [globalAttributeId], references: [id], onDelete: SetNull)
  globalAttributeId Int?
  code      String
  name      String
  nameAr    String   @default("")
  isMulti   Boolean  @default(true)
  sortOrder Int      @default(0)
  values    CategoryAttributeValue[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@index([globalAttributeId])
}

model CategoryAttributeValue {
  id          Int              @id @default(autoincrement())
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId Int
  globalValue GlobalAttributeValue? @relation(fields: [globalValueId], references: [id], onDelete: SetNull)
  globalValueId Int?
  value       String
  valueAr     String           @default("")
  sortOrder   Int              @default(0)
  productLinks ProductAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([globalValueId])
}

model ProductAttributeValue {
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  attributeValue CategoryAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  attributeValueId Int

  @@id([productId, attributeValueId])
  @@index([attributeValueId])
}

model Order {
  id           String      @id @default(uuid())
  customerName String      @default("")
  phone        String      @default("")
  city         String      @default("")
  address      String      @default("")
  notes        String?
  total        Float       @default(0)
  status       String      @default("pending")
  promoCode    String?
  discount     Float       @default(0)
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int     @default(1)
  price     Float
}

model PromoCode {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  description   String    @default("")
  discountType  String    @default("percentage")
  discountValue Float     @default(0)
  minOrder      Float     @default(0)
  maxUses       Int       @default(0)
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StoreSettings {
  id               Int      @id @default(1)
  storeName        String   @default("YOUPOSH")
  phone            String   @default("+212600000000")
  email            String   @default("contact@youposh.ma")
  currency         String   @default("MAD")
  brandPrimary     String   @default("#2563EB")
  brandSecondary   String   @default("#DC2626")
  brandColorYou    String   @default("#2563EB")
  brandColorPosh   String   @default("#DC2626")
  brandColorCart   String   @default("#2563EB")
  shippingFeeLocal    Float    @default(20)
  shippingFeeNational Float    @default(35)
  watermarkEnabled Boolean  @default(true)
  watermarkOpacity Int      @default(20)
  watermarkSize    Int      @default(30)
  watermarkPosX    Float    @default(50)
  watermarkPosY    Float    @default(50)
  activeGlobalCoupon String  @default("")
  updatedAt        DateTime @updatedAt
}

model HeroSettings {
  id               Int      @id @default(1)
  isEnabled        Boolean  @default(true)
  badgeText        String   @default("Boutique N°1 au Maroc")
  title            String   @default("Des produits tendance pour votre quotidien")
  subtitle         String   @default("Gadgets, accessoires et articles utiles sélectionnés pour vous. Livraison partout au Maroc — paiement à la livraison.")
  slogan           String   @default("Votre boutique tendance au Maroc")
  primaryCtaText   String   @default("Explorer la boutique")
  primaryCtaLink   String   @default("/shop")
  secondaryCtaText String   @default("Voir les promotions")
  secondaryCtaLink String   @default("/shop?filter=promo")
  videoEnabled     Boolean  @default(true)
  videoUrl         String   @default("/videos/demo.mp4")
  videoPosterUrl   String   @default("/images/products/headphones.jpg")
  videoAutoplay    Boolean  @default(true)
  videoMuted       Boolean  @default(true)
  videoLoop        Boolean  @default(true)
  showOnMobile     Boolean  @default(true)
  overlayOpacity   Int      @default(55)
  updatedAt        DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // "admin", "editor", "viewer"
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
