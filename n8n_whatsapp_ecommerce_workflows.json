      "typeVersion": 4,
      "position": [750, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{$env.META_PHONE_NUMBER_ID}}/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "messaging_product",
              "value": "whatsapp"
            },
            {
              "name": "to",
              "value": "={{ $('Meta Webhook').item.json.body.entry[0].changes[0].value.messages[0].from }}"
            },
            {
              "name": "type",
              "value": "text"
            },
            {
              "name": "text",
              "value": "={ \"body\": \"{{$json.candidates[0].content.parts[0].text}}\" }"
            }
          ]
        },
        "options": {}
      },
      "id": "whatsapp-send",
      "name": "Envoyer Message WhatsApp",
