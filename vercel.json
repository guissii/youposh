{
    "version": 2,
    "buildCommand": "cd backend && npm install && npx prisma generate && npx prisma migrate deploy && npm run build && cd .. && npm run build",
    "outputDirectory": "dist",
    "functions": {
        "api/index.js": {
            "includeFiles": "backend/dist/**,backend/node_modules/.prisma/**,backend/node_modules/@prisma/**,backend/prisma/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}